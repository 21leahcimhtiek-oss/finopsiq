{
  "framework": "nextjs",
  "regions": ["iad1"],
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm ci",
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}